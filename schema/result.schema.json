{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://providerbench.dev/schema/result.schema.json",
  "title": "providerbench report",
  "description": "Output of `providerbench run --json`. Submit runs as one file per run in data/results/.",
  "type": "object",
  "required": ["schema_version", "cli_version", "created_at", "provider", "system", "results"],
  "properties": {
    "schema_version": { "const": 1 },
    "cli_version": { "type": "string" },
    "category": {
      "type": "string",
      "description": "benchmark category, e.g. compute, ai, storage",
      "default": "compute"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "sample": {
      "type": "boolean",
      "description": "true = illustrative placeholder data, not a real measurement"
    },
    "provider": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "provider slug, e.g. hetzner" },
        "plan": { "type": "string", "description": "plan or instance type, e.g. cax21" },
        "region": { "type": "string" },
        "price_eur_month": { "type": "number", "minimum": 0 }
      }
    },
    "system": {
      "type": "object",
      "required": ["os", "arch", "cpu_cores"],
      "properties": {
        "os": { "type": "string" },
        "arch": { "type": "string" },
        "kernel": { "type": "string" },
        "cpu_model": { "type": "string" },
        "cpu_cores": { "type": "integer", "minimum": 1 },
        "mem_total_mb": { "type": "integer", "minimum": 0 },
        "virtualization": { "type": "string" }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test", "started_at", "duration_seconds", "metrics"],
        "properties": {
          "test": { "type": "string" },
          "started_at": { "type": "string", "format": "date-time" },
          "duration_seconds": { "type": "number", "minimum": 0 },
          "metrics": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "value", "unit", "higher_is_better"],
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "number" },
                "unit": { "type": "string" },
                "higher_is_better": { "type": "boolean" }
              }
            }
          },
          "notes": { "type": "array", "items": { "type": "string" } },
          "error": { "type": "string" }
        }
      }
    }
  }
}
